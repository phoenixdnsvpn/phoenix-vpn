<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_global_settings"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Global Settings"
            app:titleTextColor="?attr/colorOnSurface"
            app:navigationIcon="@drawable/ic_arrow_back_modern"
            app:navigationIconTint="?attr/colorOnSurface" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Startup Behavior"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/cb_default_configs_at_start"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable Default Configs at Start"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                app:thumbTint="?attr/colorPrimary"
                android:layout_marginBottom="16dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/cb_default_vpn_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Start in VPN Mode by default"
                android:textColor="?attr/colorOnSurface"
                app:thumbTint="?attr/colorPrimary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/dividerVertical"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menu Visibility"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/cb_show_check_app_update"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show 'Check for Update'"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                app:thumbTint="?attr/colorPrimary"
                android:layout_marginBottom="16dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/cb_show_update_configs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show 'Update Configs'"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                app:thumbTint="?attr/colorPrimary"
                android:layout_marginBottom="16dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/cb_show_update_resolvers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show 'Update Resolvers'"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                app:thumbTint="?attr/colorPrimary"
                android:layout_marginBottom="16dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/cb_show_upload_configs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show 'Upload Configs'"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                app:thumbTint="?attr/colorPrimary"
                android:layout_marginBottom="16dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/cb_show_upload_resolvers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show 'Upload Resolvers'"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                app:thumbTint="?attr/colorPrimary"
                android:layout_marginBottom="24dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/cb_show_import_resolvers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show 'Import Resolvers'"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                app:thumbTint="?attr/colorPrimary"
                android:layout_marginBottom="16dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/cb_show_export_resolvers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show 'Export Resolvers'"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                app:thumbTint="?attr/colorPrimary"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>