<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_tunnel_settings"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Pre Tunnel Scanner"
            app:titleTextColor="?attr/colorOnSurface"
            app:navigationIcon="@drawable/ic_arrow_back_modern"
            app:navigationIconTint="?attr/colorOnSurface" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/cb_enable_prescan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable Pre-Tunnel Scan"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:checked="true"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Proxy Type:"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rg_proxy_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/rb_proxy_socks5h"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="socks5h"
                    android:checked="true"
                    android:layout_weight="1"
                    android:buttonTint="?attr/colorPrimary"
                    android:textColor="?attr/colorOnSurface" />

                <RadioButton
                    android:id="@+id/rb_proxy_socks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="socks"
                    android:layout_weight="1"
                    android:buttonTint="?attr/colorPrimary"
                    android:textColor="?attr/colorOnSurface" />

                <RadioButton
                    android:id="@+id/rb_proxy_http"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="http"
                    android:layout_weight="1"
                    android:buttonTint="?attr/colorPrimary"
                    android:textColor="?attr/colorOnSurface" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan mode:"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rg_scan_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/rb_light_e2e"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Light E2E"
                    android:checked="true"
                    android:layout_weight="1"
                    android:buttonTint="?attr/colorPrimary"
                    android:textColor="?attr/colorOnSurface" />

                <RadioButton
                    android:id="@+id/rb_true_e2e"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="True E2E"
                    android:checked="true"
                    android:layout_weight="1"
                    android:buttonTint="?attr/colorPrimary"
                    android:textColor="?attr/colorOnSurface" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Workers:"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/et_workers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tunnel Wait (ms):"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="16dp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/et_tunnel_wait"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Probe Timeout (ms):"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="16dp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/et_probe_timeout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UDP Timeout (ms):"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="16dp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/et_udp_timeout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Retry:"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="16dp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/et_retries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="?attr/colorOnSurface" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>