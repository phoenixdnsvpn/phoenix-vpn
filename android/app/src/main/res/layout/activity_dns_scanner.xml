<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_scanner"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Scanner parameters"
            app:titleTextColor="?attr/colorOnSurface"
            app:navigationIcon="@drawable/ic_arrow_back_modern"
            app:navigationIconTint="?attr/colorOnSurface" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tunnel Domain:"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_domain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false"
                android:backgroundTint="?attr/colorPrimary"
                android:textColor="?attr/colorPrimary" />

            <TextView
                android:id="@+id/tv_tunnel_mode_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Tunnel Mode:"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:visibility="gone" />

            <RadioGroup
                android:id="@+id/rg_tunnel_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <RadioButton
                    android:id="@+id/rb_mode_udp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="?attr/colorPrimary"
                    android:checked="true"
                    android:text="UDP"
                    android:textColor="?attr/colorOnSurface" />

                <RadioButton
                    android:id="@+id/rb_mode_tcp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="?attr/colorPrimary"
                    android:text="TCP"
                    android:textColor="?attr/colorOnSurface" />

                <RadioButton
                    android:id="@+id/rb_mode_dot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="?attr/colorPrimary"
                    android:text="DoT"
                    android:textColor="?attr/colorOnSurface" />

                <RadioButton
                    android:id="@+id/rb_mode_doh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="?attr/colorPrimary"
                    android:text="DoH"
                    android:textColor="?attr/colorOnSurface" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Proxy Type:"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="16dp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rg_proxy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rb_socks5h"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="socks5h"
                    android:checked="true"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary" />

                <RadioButton
                    android:id="@+id/rb_socks5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="socks5"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary" />

                <RadioButton
                    android:id="@+id/rb_http"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="http"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary" />
            </RadioGroup>

            <Button
                android:id="@+id/btn_start_scan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="START SCAN"
                android:backgroundTint="?attr/colorPrimary"
                android:textColor="?attr/colorOnPrimary"
                android:layout_marginTop="16dp" />

            <Switch
                android:id="@+id/switch_public_dns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Use Public DNS Resolvers"
                android:textColor="?attr/colorOnSurface"
                android:checked="true"
                android:layout_marginTop="20dp"
                android:thumbTint="?attr/colorPrimary" />

            <Switch
                android:id="@+id/switch_cidr_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Use CIDR Block"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="20dp"
                android:thumbTint="?attr/colorPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resolvers Source:"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="20dp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rg_resolver_source"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rb_source_custom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Use custom resolvers"
                    android:checked="true"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary" />

                <RadioButton
                    android:id="@+id/rb_source_paste"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Use Copy &amp; Paste resolvers"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary" />

                <RadioButton
                    android:id="@+id/rb_source_default"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Use default resolvers"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary" />

                <RadioButton
                    android:id="@+id/rb_source_encrypted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Use encrypted resolvers"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary" />
            </RadioGroup>

            <Button
                android:id="@+id/btn_action_resolvers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="IMPORT RESOLVERS"
                android:enabled="true"
                android:backgroundTint="?attr/colorPrimary"
                android:textColor="?attr/colorOnPrimary"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tv_resolvers_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loaded resolvers: 0"
                android:layout_marginTop="8dp"
                android:textColor="?android:attr/textColorSecondary" />

            <LinearLayout
                android:id="@+id/layout_cidr_selection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_selected_cidr"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="No CIDR Selected"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnSurface" />

                <ImageButton
                    android:id="@+id/btn_select_cidr"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?attr/colorPrimary"
                    android:contentDescription="Select CIDR Block" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Number of Resolvers to scan:"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="20dp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_num_resolvers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="?attr/colorOnSurface"
                android:text="5000" />

            <Switch
                android:id="@+id/switch_conservative"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Use Conservative Scan"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="20dp"
                android:thumbTint="?attr/colorPrimary" />

            <Switch
                android:id="@+id/switch_random"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Use Random Resolvers"
                android:textColor="?attr/colorOnSurface"
                android:checked="true"
                android:layout_marginTop="20dp"
                android:thumbTint="?attr/colorPrimary" />

            <TextView
                android:id="@+id/tv_e2e_mode_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan Mode:"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="20dp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rg_e2e_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rb_light_e2e"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Light E2E"
                    android:checked="true"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary" />

                <RadioButton
                    android:id="@+id/rb_true_e2e"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="True E2E"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary" />
            </RadioGroup>

            <TextView
                android:id="@+id/tv_quick_scan_mode_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Scan Mode:"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="20dp"
                android:textStyle="bold"
                android:visibility="gone" />

            <RadioGroup
                android:id="@+id/rg_quick_scan_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <RadioButton
                    android:id="@+id/rb_quick_dns_check"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick DNS Check"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary" />

                <RadioButton
                    android:id="@+id/rb_light_e2e_quick"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Light E2E"
                    android:checked="true"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorPrimary" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Workers:"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="20dp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_workers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="?attr/colorOnSurface"
                android:text="20" />

            <TextView
                android:id="@+id/tv_tunnel_wait_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tunnel Wait (ms):"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="20dp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_tunnel_wait"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="?attr/colorOnSurface"
                android:text="3000" />

            <TextView
                android:id="@+id/tv_probe_timeout_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Probe Timeout (seconds):"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="20dp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_probe_timeout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="?attr/colorOnSurface"
                android:text="15" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UDP Timeout (ms):"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="20dp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_udp_timeout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="?attr/colorOnSurface"
                android:text="1000" />

            <TextView
                android:id="@+id/tv_retries_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Retry:"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginTop="20dp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_retries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="?attr/colorOnSurface"
                android:text="1" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>